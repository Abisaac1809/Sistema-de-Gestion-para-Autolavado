// Prisma Schema for Car Wash Management System

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum ExchangeRateSource {
  BCV_USD
  BCV_EUR
  CUSTOM
}

enum UnitType {
  LITERS
  MILLILITERS
  KILOGRAMS
  GRAMS
  UNITS
  BOXES
  BOTTLES
}

enum AdjustmentType {
  IN
  OUT
}

enum AdjustmentReason {
  DAMAGED
  EXPIRED
  THEFT
  AUDIT_CORRECTION
  SPILLED
  OTHER
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
}

enum Currency {
  USD
  VES
  EUR
}

enum SaleStatus {
  COMPLETED
  REFUNDED
  CANCELLED
}

// ============================================================================
// MODELS
// ============================================================================

model StoreInfo {
  id          String    @id @default(uuid())
  name        String
  rif         String    @unique
  address     String
  phone       String
  logoUrl     String?   @map("logo_url")
  singleton   Boolean   @unique @default(true)
  lastUpdated DateTime  @default(now()) @map("last_updated")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  @@map("store_info")
}

model ExchangeRateConfig {
  id           String             @id @default(uuid())
  activeSource ExchangeRateSource @default(BCV_USD) @map("active_source")
  customRate   Decimal            @default(0) @map("custom_rate")
  bcvUsdRate   Decimal            @default(0) @map("bcv_usd_rate")
  bcvEurRate   Decimal            @default(0) @map("bcv_eur_rate")
  autoUpdate   Boolean            @default(true) @map("auto_update")
  lastSync     DateTime           @default(now()) @map("last_sync")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  deletedAt    DateTime?          @map("deleted_at")

  @@map("exchange_rate_config")
}

model NotificationContact {
  id             String    @id @default(uuid())
  fullName       String?   @map("full_name")
  email          String    @unique
  receiveReports Boolean   @default(true) @map("receive_reports")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  @@map("notification_contacts")
}

model ProductCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  status      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  products Product[]

  @@map("product_categories")
}

model Product {
  id         String    @id @default(uuid())
  categoryId String?   @map("category_id")
  name       String
  stock      Decimal   @default(0)
  minStock   Decimal   @default(0) @map("min_stock")
  unitType   UnitType? @map("unit_type")
  costPrice  Decimal   @map("cost_price")
  isForSale  Boolean   @default(false) @map("is_for_sale")
  status     Boolean   @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  // Relations
  category             ProductCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  inventoryAdjustments InventoryAdjustment[]
  orderDetails         OrderDetail[]
  saleDetails          SaleDetail[]
  purchaseDetails      PurchaseDetail[]

  @@index([categoryId])
  @@index([name])
  @@index([status])
  @@map("products")
}

model InventoryAdjustment {
  id             String           @id @default(uuid())
  productId      String           @map("product_id")
  adjustmentType AdjustmentType   @map("adjustment_type")
  quantity       Decimal
  stockBefore    Decimal          @map("stock_before")
  stockAfter     Decimal          @map("stock_after")
  reason         AdjustmentReason
  notes          String?
  createdAt      DateTime         @default(now()) @map("created_at")

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([adjustmentType])
  @@index([createdAt])
  @@map("inventory_adjustments")
}

model Service {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Decimal

  status    Boolean   @default(true)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  orderDetails OrderDetail[]
  saleDetails  SaleDetail[]

  @@index([status])
  @@map("services")
}

model Customer {
  id        String    @id @default(uuid())
  fullName  String    @map("full_name")
  idNumber  String?   @unique @map("id_number")
  phone     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  orders Order[]
  sales  Sale[]

  @@index([phone])
  @@map("customers")
}

model PaymentMethod {
  id            String    @id @default(uuid())
  name          String
  description   String?
  currency      Currency?
  bankName      String?   @map("bank_name")
  accountHolder String?   @map("account_holder")
  accountNumber String?   @map("account_number")
  idCard        String?   @map("id_card")
  phoneNumber   String?   @map("phone_number")
  email         String?
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Relations
  payments  Payment[]
  purchases Purchase[]

  @@index([isActive])
  @@map("payment_methods")
}

model Order {
  id             String        @id @default(uuid())
  customerId     String        @map("customer_id")
  vehiclePlate   String?       @map("vehicle_plate")
  vehicleModel   String        @map("vehicle_model")
  status         OrderStatus   @default(PENDING)
  paymentStatus  PaymentStatus @default(PENDING) @map("payment_status")
  startedAt      DateTime?     @map("started_at")
  completedAt    DateTime?     @map("completed_at")
  dollarRate     Decimal       @default(1)  @map("dollar_rate")
  totalUsd       Decimal                    @map("total_usd")
  totalVes       Decimal       @default(0)  @map("total_ves")
  totalPaidUsd   Decimal       @default(0)  @map("total_paid_usd")
  totalPaidVes   Decimal       @default(0)  @map("total_paid_ves")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  deletedAt      DateTime?     @map("deleted_at")

  // Relations
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  orderDetails OrderDetail[]
  sale         Sale?
  payments     Payment[]

  @@index([customerId])
  @@index([status])
  @@index([vehiclePlate])
  @@index([createdAt])
  @@map("orders")
}

model OrderDetail {
  id          String    @id @default(uuid())
  orderId     String    @map("order_id")
  serviceId   String?   @map("service_id")
  productId   String?   @map("product_id")
  quantity    Decimal
  priceAtTime Decimal   @map("price_at_time")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([serviceId])
  @@index([productId])
  @@map("order_details")
}

model Sale {
  id            String        @id @default(uuid())
  customerId    String        @map("customer_id")
  orderId       String?       @unique @map("order_id")
  totalUsd      Decimal       @map("total_usd")
  totalVes      Decimal       @map("total_ves")
  dollarRate    Decimal       @map("dollar_rate")
  status        SaleStatus    @default(COMPLETED)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  deletedAt     DateTime?     @map("deleted_at")

  // Relations
  customer    Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  order       Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  saleDetails SaleDetail[]
  payments    Payment[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@map("sales")
}

model SaleDetail {
  id        String    @id @default(uuid())
  saleId    String    @map("sale_id")
  serviceId String?   @map("service_id")
  productId String?   @map("product_id")
  quantity  Decimal
  unitPrice Decimal   @map("unit_price")
  subtotal  Decimal
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  service Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([saleId])
  @@index([serviceId])
  @@index([productId])
  @@map("sale_details")
}

model Purchase {
  id              String    @id @default(uuid())
  providerName    String    @map("provider_name")
  purchaseDate    DateTime  @default(now()) @map("purchase_date")
  dollarRate      Decimal   @map("dollar_rate")
  totalUsd        Decimal   @map("total_usd")
  notes           String?
  paymentMethodId String?   @map("payment_method_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  // Relations
  purchaseDetails PurchaseDetail[]
  paymentMethod   PaymentMethod?   @relation(fields: [paymentMethodId], references: [id])

  @@index([purchaseDate])
  @@index([paymentMethodId])
  @@map("purchases")
}

model PurchaseDetail {
  id          String    @id @default(uuid())
  purchaseId  String    @map("purchase_id")
  productId   String    @map("product_id")
  quantity    Decimal
  unitCostUsd Decimal   @map("unit_cost_usd")
  subtotalUsd Decimal   @map("subtotal_usd")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([productId])
  @@map("purchase_details")
}

model Payment {
  id               String    @id @default(uuid())
  orderId          String?   @map("order_id")
  saleId           String?   @map("sale_id")
  paymentMethodId  String    @map("payment_method_id")
  amountUsd        Decimal   @map("amount_usd")
  exchangeRate     Decimal   @map("exchange_rate")
  amountVes        Decimal   @map("amount_ves")
  originalCurrency Currency  @default(USD) @map("original_currency")
  paymentDate      DateTime  @default(now()) @map("payment_date")
  notes            String?
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  // Relations
  order         Order?        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sale          Sale?         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([saleId])
  @@index([paymentMethodId])
  @@index([paymentDate])
  @@map("payments")
}
