{
  "name": "car-wash-desktop",
  "version": "0.0.1",
  "description": "Electron wrapper for Car Wash Management System",
  "license": "MIT",
  "author": "Abisaac Carmona",
  "main": "dist/main.js",
  "scripts": {
    "compile": "tsc",
    "dev": "tsc && electron .",
    "dev:linux": "tsc && DISPLAY=${DISPLAY:-:0} electron --gtk-version=3 .",
    "build:api": "node build-api.mjs",
    "build": "tsc && node build-api.mjs && electron-builder",
    "build:linux": "tsc && node build-api.mjs && electron-builder --linux"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "esbuild": "^0.25.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3"
  }
}
